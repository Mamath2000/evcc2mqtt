# evcc API
EVCC_HOST=192.168.1.50
EVCC_PORT=7070
EVCC_LANG=fr

# MQTT broker
MQTT_URL=mqtt://192.168.100.10:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Topics
TOPIC_PREFIX=evcc2mqtt
HA_DISCOVERY_PREFIX=homeassistant
# Topic to read the fixed vehicle consumption from, in Wh/km (numeric payload)
CONSO_TOPIC=evcc2mqtt/config/conso_wh_km

# How often to refresh and republish today's sensors (ms)
POLL_INTERVAL_MS=60000

# Log verbosity: error, info, debug
LOG_LEVEL=info
